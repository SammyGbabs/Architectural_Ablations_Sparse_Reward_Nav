# Ignore the virtual environment directory
Rl_Summative/

# Ignore Python bytecode files
*.pyc
*.pyo
__pycache__/

# Ignore system-specific files
.DS_Store  # macOS
Thumbs.db  # Windows

# Ignore IDE-specific files
.vscode/
.idea/
.ipynb_checkpoints/

# Scratch / exploratory notebooks (not version-controlled)
Notebooks/scratch/

# Experiment tracking and training artifacts
wandb/
*.tfevents.*
*_tensorboard/
*.zip
*.npz

# Generated figure exports (PNGs are tracked; vector/PDF exports are not)
figures/*.svg
figures/*.pdf
